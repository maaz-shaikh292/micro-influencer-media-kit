# Supabase — copy this file to .env.local and fill in values from
# https://app.supabase.com/project/<project>/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — used by /api/analyze to read metrics from uploaded screenshots.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Public site URL used to build Stripe redirect URLs (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# From the webhook endpoint you create (or `stripe listen` for local dev).
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe Products (Pricing). Monthly = recurring, Lifetime = one-time.
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_LIFETIME=price_...
